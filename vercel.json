{
  "routes": [
    {
      "src": "/.well-known/(.*)",
      "dest": "/.well-known/$1"
    },
    {
      "src": "/download",
      "dest": "/api/download"
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "link.snaplink.run"
        }
      ],
      "dest": "/api/link"
    },
    {
      "src": "/auth/apple/callback",
      "methods": ["POST"],
      "dest": "/api/auth/apple/callback"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(?:ico|png|jpg|jpeg|svg|webp|gif|txt|json|xml))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}